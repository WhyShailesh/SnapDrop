# Server
PORT=3001
NODE_ENV=development

# MongoDB (use mongodb://localhost:27017 for local)
MONGODB_URI=mongodb://localhost:27017/codedrop

# Encryption (32-byte hex for AES-256; generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ENCRYPTION_PEPPER=your_32_byte_hex_secret_here

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
